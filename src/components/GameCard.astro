---
import type { Game } from '@/lib/data';

interface Props {
  game: Game;
}

const { game } = Astro.props;
---

<article class="surface rounded-lg p-5">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.18em] text-mint">{game.category}</p>
      <h2 class="mt-2 text-2xl font-black text-white">{game.name}</h2>
    </div>
    <span class="rounded-md border border-cyan/30 px-2.5 py-1 text-xs font-black text-cyan">{game.status}</span>
  </div>
  <p class="mt-4 text-sm leading-6 text-white/72">{game.summary}</p>
  <div class="mt-5 grid grid-cols-3 gap-2 text-center text-xs font-bold">
    <a class="rounded-md bg-white/8 px-2 py-3 text-white transition hover:bg-mint hover:text-ink" href={`/games/${game.slug}`}>Game</a>
    <a class="rounded-md bg-white/8 px-2 py-3 text-white transition hover:bg-mint hover:text-ink" href={`/tier-list/${game.slug}`}>Tier</a>
    <a class="rounded-md bg-white/8 px-2 py-3 text-white transition hover:bg-mint hover:text-ink" href={`/compare/${game.slug}`}>Compare</a>
  </div>
</article>
