---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<a
  class={className}
  href="#"
  data-email-user="hello"
  data-email-domain="bloxtier.com"
  aria-label="Email BloxTier"
>Email BloxTier</a>

<script>
  document.querySelectorAll<HTMLAnchorElement>('[data-email-user][data-email-domain]').forEach((link) => {
    const user = link.dataset.emailUser;
    const domain = link.dataset.emailDomain;
    if (!user || !domain) return;

    const address = `${user}@${domain}`;
    link.href = `mailto:${address}`;
    link.textContent = address;
  });
</script>
