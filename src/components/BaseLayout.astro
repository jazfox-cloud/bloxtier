---
import '../styles/global.css';
import { canonical, navItems, site } from '@/lib/site';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = site.name,
  description = site.description,
  path = '/'
} = Astro.props;

const pageTitle = title === site.name ? `${site.name} - Roblox Tier Lists and Compare Tools` : `${title} | ${site.name}`;
const url = canonical(path);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={new URL('/arena-grid.svg', site.url).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-mint/15 bg-ink/88 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
        <a href="/" class="flex items-center gap-3" aria-label="BloxTier home">
          <img src="/favicon.svg" alt="" class="h-8 w-8" />
          <span class="text-lg font-black tracking-normal text-white">BloxTier</span>
        </a>
        <nav class="hidden items-center gap-1 md:flex" aria-label="Primary navigation">
          {navItems.map((item) => (
            <a class="rounded-md px-3 py-2 text-sm font-semibold text-white/72 transition hover:bg-white/8 hover:text-white" href={item.href}>
              {item.label}
            </a>
          ))}
        </nav>
        <a href="/compare/blue-lock-rivals/" class="rounded-md border border-mint/40 bg-mint px-3 py-2 text-sm font-black text-ink shadow-glow transition hover:bg-lime">
          Compare
        </a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-mint/15 bg-ink/92">
      <div class="mx-auto grid max-w-7xl gap-6 px-4 py-8 text-sm text-white/64 sm:px-6 md:grid-cols-[1.4fr_1fr] lg:px-8">
        <div>
          <p class="font-black text-white">BloxTier</p>
          <p class="mt-2 max-w-2xl">
            Independent Roblox tier list and compare tools. We are not affiliated with Roblox, FIFA, Gamefam, or the listed game developers.
          </p>
        </div>
        <div class="flex flex-wrap items-start gap-3 md:justify-end">
          <a class="hover:text-white" href="/about/">About</a>
          <a class="hover:text-white" href="/contact/">Contact</a>
          <a class="hover:text-white" href="/privacy/">Privacy</a>
          <a class="hover:text-white" href="/terms/">Terms</a>
          <a class="hover:text-white" href="/sitemap.xml">Sitemap</a>
        </div>
      </div>
    </footer>
  </body>
</html>
