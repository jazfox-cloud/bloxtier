---
import BaseLayout from '@/components/BaseLayout.astro';
import CompareTool from '@/components/CompareTool.astro';
import { games, getGame, getTierItems } from '@/lib/data';

export function getStaticPaths() {
  return games.map((game) => ({ params: { slug: game.slug } }));
}

const game = getGame(Astro.params.slug || '');
if (!game) return Astro.redirect('/');
const items = getTierItems(game.slug);
---

<BaseLayout title={`${game.name} Compare Tool`} description={`Compare ${game.name} picks by pressure, mobility, control, and consistency.`} path={`/compare/${game.slug}/`}>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-6">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-cyan">Compare tool</p>
      <h1 class="mt-2 text-4xl font-black text-white md:text-5xl">{game.name} Compare</h1>
      <p class="mt-3 max-w-3xl text-white/68">Pick two entries and compare their pressure, mobility, control, and consistency profiles. This is designed for quick matchup thinking, not fake official stats.</p>
    </div>
    <CompareTool items={items} />
  </section>
</BaseLayout>
