---
import BaseLayout from '@/components/BaseLayout.astro';
import EmailLink from '@/components/EmailLink.astro';
---
<BaseLayout title="Contact BloxTier" description="Contact BloxTier about tier-list corrections, code status, sources, privacy, or accessibility." path="/contact/">
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8"><div class="surface rounded-lg p-6 md:p-8"><p class="text-sm font-black uppercase tracking-[0.2em] text-mint">Contact</p><h1 class="mt-2 text-4xl font-black text-white">Contact BloxTier</h1><div class="mt-6 space-y-4 text-base leading-8 text-white/72"><p>Email <EmailLink class="text-mint" /> for tier-list corrections, code updates, source suggestions, privacy requests, or accessibility reports.</p><p>Include the page URL, the exact ranking or code to review, and an official or clearly identified community source. BloxTier cannot provide Roblox account support or redeem codes.</p><p>BloxTier is an independent fan site and is not affiliated with Roblox Corporation or any game developer.</p></div></div></section>
</BaseLayout>
