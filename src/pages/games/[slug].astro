---
import BaseLayout from '@/components/BaseLayout.astro';
import { games, getGame, getTierItems } from '@/lib/data';

export function getStaticPaths() {
  return games.map((game) => ({ params: { slug: game.slug } }));
}

const game = getGame(Astro.params.slug || '');
if (!game) return Astro.redirect('/');
const tiers = getTierItems(game.slug);
---

<BaseLayout title={`${game.name} Tools`} description={game.seo.overview} path={`/games/${game.slug}/`}>
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="surface rounded-lg p-6 md:p-8">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-mint">{game.category}</p>
      <h1 class="mt-3 text-4xl font-black text-white md:text-6xl">{game.name}</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-white/72">{game.summary}</p>
      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <a class="rounded-md bg-mint px-4 py-3 text-center font-black text-ink transition hover:bg-lime" href={`/tier-list/${game.slug}/`}>Tier List</a>
        <a class="rounded-md border border-cyan/40 px-4 py-3 text-center font-black text-cyan transition hover:bg-cyan hover:text-ink" href={`/compare/${game.slug}/`}>Compare</a>
        <a class="rounded-md border border-white/15 px-4 py-3 text-center font-black text-white transition hover:bg-white hover:text-ink" href={`/codes/${game.slug}/`}>Codes</a>
      </div>
    </div>
    <div class="mt-6 grid gap-5 md:grid-cols-[1fr_0.86fr]">
      <section class="surface rounded-lg p-5">
        <h2 class="text-2xl font-black text-white">Evidence notes</h2>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-white/70">
          {game.evidence.map((item) => <li class="rounded-md bg-white/6 p-3">{item}</li>)}
        </ul>
      </section>
      <aside class="surface rounded-lg p-5">
        <h2 class="text-2xl font-black text-white">Next update</h2>
        <p class="mt-4 text-sm leading-6 text-white/70">{game.nextStep}</p>
        <p class="mt-5 text-xs font-black uppercase tracking-[0.16em] text-mint">Tier entries: {tiers.length}</p>
      </aside>
    </div>
  </section>
</BaseLayout>
