---
import BaseLayout from '@/components/BaseLayout.astro';
import { games, getCodeRecords, getGame } from '@/lib/data';

export function getStaticPaths() {
  return games.map((game) => ({ params: { slug: game.slug } }));
}

const game = getGame(Astro.params.slug || '');
if (!game) return Astro.redirect('/');
const records = getCodeRecords(game.slug);
---

<BaseLayout title={`${game.name} Codes`} description={`Verified ${game.name} code status and update queue.`} path={`/codes/${game.slug}/`}>
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="surface rounded-lg p-6 md:p-8">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-mint">Codes</p>
      <h1 class="mt-2 text-4xl font-black text-white md:text-5xl">{game.name} Codes</h1>
      <p class="mt-4 text-white/70">BloxTier only marks codes active after a direct verification path. Candidate sources stay separate from active code tables.</p>
    </div>
    <div class="mt-6 space-y-4">
      {records.map((record) => (
        <article class="surface rounded-lg p-5">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-xs font-black uppercase tracking-[0.16em] text-cyan">{record.status.replace('-', ' ')}</p>
              <h2 class="mt-2 text-2xl font-black text-white">{record.code || 'No verified active code published'}</h2>
            </div>
            <span class="rounded-md border border-mint/30 px-3 py-1 text-xs font-black text-mint">Checked {record.checkedAt}</span>
          </div>
          {record.reward && <p class="mt-3 text-white/78">{record.reward}</p>}
          <p class="mt-4 text-sm leading-6 text-white/66">{record.notes}</p>
          {record.sourceUrl && <a class="mt-4 inline-flex text-sm font-black text-mint hover:text-lime" href={record.sourceUrl} rel="nofollow">Source queue: {record.sourceLabel}</a>}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
