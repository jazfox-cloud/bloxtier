---
import BaseLayout from '@/components/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="BloxTier privacy policy." path="/privacy/">
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="surface rounded-lg p-6 md:p-8">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-mint">Privacy</p>
      <h1 class="mt-2 text-4xl font-black text-white">Privacy Policy</h1>
      <div class="mt-6 space-y-4 text-base leading-8 text-white/72">
        <p>BloxTier is a static information site. We do not ask visitors to create accounts or submit personal information in the MVP.</p>
        <p>Hosting providers, analytics tools, or security services may process standard technical data such as IP address, user agent, referrer, and request time.</p>
        <p>Contact and analytics details will be updated here before any form, login, newsletter, or advertising system is added.</p>
      </div>
    </div>
  </section>
</BaseLayout>
